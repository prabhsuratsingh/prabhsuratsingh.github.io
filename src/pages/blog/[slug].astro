---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
	const blogPosts = await getCollection("blog");
	return blogPosts.map((post) => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout>
	<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
		<a
			href="/blog"
			class="block text-sm opacity-60 hover:opacity-100 transition-opacity mb-12"
		>
			← Back to all articles
		</a>
		<article>
			<header class="mb-12">
				<p class="text-xs opacity-50 mb-3 uppercase tracking-wider">
					{
						post.data.date.toLocaleDateString("en-US", {
							year: "numeric",
							month: "long",
							day: "numeric",
						})
					}
				</p>

				<h1 class="text-3xl md:text-4xl font-serif font-bold mb-4">
					{post.data.title}
				</h1>

				<p class="text-sm opacity-60 mb-4">
					{post.data.readTime} min read
				</p>

				{post.data.tags && (
            <div class="flex gap-2">
              {post.data.tags.map((tag: string) => (
                <span class="border border-current px-2 py-1">
                  #{tag}
                </span>
              ))}
            </div>
          )}
			</header>

			<div class="prose prose-lg max-w-none">
				<Content />
			</div>

			<footer class="border-t border-border mt-12 pt-8 text-sm opacity-60">
				<p>
					Published on {
						post.data.date.toLocaleDateString("en-US", {
							year: "numeric",
							month: "long",
							day: "numeric",
						})
					}
				</p>
			</footer>
		</article>
	</div>
</Layout>

<style is:global>
	.prose {
		color: rgb(var(--text));
	}

	.prose h1,
	.prose h2,
	.prose h3,
	.prose h4 {
		font-weight: bold;
		margin-top: 2rem;
		margin-bottom: 1rem;
	}

	.prose h1 {
		font-size: 1.875rem;
	}

	.prose h2 {
		font-size: 1.5rem;
	}

	.prose h3 {
		font-size: 1.25rem;
	}

	.prose p {
		margin-bottom: 1rem;
		line-height: 1.75;
	}

	.prose ul,
	.prose ol {
		margin-bottom: 1rem;
		margin-left: 1.5rem;
	}

	.prose li {
		margin-bottom: 0.5rem;
	}

	.prose ul {
		list-style-type: disc;
	}

	.prose ol {
		list-style-type: decimal;
	}

	.prose a {
		text-decoration: underline;
	}

	.prose a:hover {
		text-decoration: none;
	}

	.prose code {
		background: rgb(var(--text));
		color: rgb(var(--bg));
		padding: 0.25rem 0.5rem;
	}

	.prose pre {
		border: 2px solid rgb(var(--text));
		padding: 1rem;
		overflow-x: auto;
		margin-bottom: 1rem;
	}

	.prose pre code {
		background: transparent;
		color: inherit;
		padding: 0;
	}

	.prose blockquote {
		border-left: 4px solid rgb(var(--text));
		padding-left: 1rem;
		font-style: italic;
		margin: 1rem 0;
	}

	.prose strong {
		font-weight: bold;
	}

	.prose em {
		font-style: italic;
	}
</style>
