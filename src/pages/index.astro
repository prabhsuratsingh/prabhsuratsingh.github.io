---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import projects from "../data/projects.json";
import scratch from "../data/from_scratch.json";

const allBlogPosts = await getCollection("blog");
const latestBlogs = allBlogPosts
	.sort((a: any, b: any) => b.data.date.getTime() - a.data.date.getTime())
	.slice(0, 3);
---

<Layout>
	<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
		<section class="mb-16">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
				<div class="md:col-span-2">
					<h1 class="text-3xl md:text-4xl font-serif font-bold mb-4">
						Hi!
					</h1>

					<p class="text-sm opacity-70 mb-6 leading-relaxed">
						I’m <strong>Prabhsurat Singh</strong> — a software engineer
						from New Delhi, India, with a Bachelor's degree in Computer
						Science and a minor in Artificial Intelligence and Machine
						Learning.
						<br />
						<br />
						I spend most of my time building machine learning systems,
						backend infrastructure, and developer tools. My primary interests
						are <strong
							>Reinforcement Learning, LLM post-training, and Deep
							Learning</strong
						>, where I work on everything from RL algorithms and
						training pipelines to <strong>GPU programming</strong> and
						model optimization.
						<br />
						<br />
						Alongside ML research, I enjoy building distributed backend
						systems and high-performance infrastructure using Python,
						C++, PyTorch, CUDA, FastAPI, Docker, Redis, Kafka, and PostgreSQL.
						I'm driven by a systems-first mindset—taking ambitious ideas
						from research to production-ready software.
					</p>

					<div class="flex gap-4">
						<a
							href="/blog"
							class="text-sm border border-foreground px-4 py-2 hover:bg-foreground hover:text-background transition-colors"
						>
							Read Blog
						</a>

						<a
							href="mailto:prabhsurat.tech@gmail.com"
							class="text-sm border border-foreground px-4 py-2 hover:bg-foreground hover:text-background transition-colors"
						>
							Get in Touch
						</a>
					</div>
				</div>

				<div class="md:col-span-1">
					<div
						class="w-42 h-52 mt-4 bg-muted-foreground/20 rounded-lg border border-border flex items-center justify-center"
					>
						<img
							src="/images/about-pic.jpeg"
							alt="Profile Photo"
							class="w-42 h-52 rounded-lg border border-border object-cover"
						/>
					</div>
				</div>
			</div>
		</section>

		<section class="mb-16">
			<div class="mb-8">
				<h2 class="text-2xl font-serif font-bold mb-2">
					Latest Articles
				</h2>
				<p class="text-sm opacity-60">
					Thoughts on RL, systems, development and more
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				{
					latestBlogs.map((blog: any) => (
						<a
							href={`/blog/${blog.slug}`}
							class="group border border-border hover:bg-muted-foreground/10 transition-colors overflow-hidden"
						>
							{blog.data.cover && (
								<img
									src={blog.data.cover}
									alt={blog.data.title}
									class="w-full h-44 object-contain bg-white border-b border-border p-3"
								/>
							)}

							<div class="p-6">
								<time class="text-xs opacity-50 uppercase tracking-wider">
									{blog.data.date.toLocaleDateString(
										"en-US",
										{
											year: "numeric",
											month: "long",
											day: "numeric",
										},
									)}
								</time>

								<h3 class="font-serif font-bold mt-2 mb-3 group-hover:underline">
									{blog.data.title}
								</h3>

								<p class="text-sm opacity-70 line-clamp-2">
									{blog.data.description}
								</p>

								<p class="text-xs opacity-40 mt-4">
									{blog.data.readTime} min read
								</p>
							</div>
						</a>
					))
				}
			</div>

			<div class="mt-6">
				<a
					href="/blog"
					class="text-sm opacity-60 hover:opacity-100 transition-opacity underline"
				>
					View all articles →
				</a>
			</div>
		</section>

		<!-- From Scratch -->
		<section class="mb-16">
			<div class="mb-8">
				<h2 class="text-2xl font-serif font-bold mb-2">From Scratch</h2>
				<p class="text-sm opacity-60">
					Implementations of research papers, books, and algorithms to
					understand them from first principles.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				{
					scratch.slice(0, 2).map((impl) => (
						<a
							href={impl.github}
							target="_blank"
							rel="noopener noreferrer"
							class="group border border-border hover:bg-muted-foreground/10 transition-colors overflow-hidden"
						>
							{impl.image && (
								<img
									src={impl.image}
									alt={impl.name}
									class="w-full h-44 object-contain bg-white border-b border-border p-3"
								/>
							)}

							<div class="p-6">
								<h3 class="font-serif font-bold mb-3 group-hover:underline">
									{impl.name}
								</h3>

								<p class="text-sm opacity-70 line-clamp-2 mb-4">
									{impl.description}
								</p>

								<div class="flex flex-wrap gap-2 mb-4">
									{impl.languages.map((lang) => (
										<span class="text-xs px-2 py-1 border border-border opacity-60">
											{lang}
										</span>
									))}
								</div>

								<p class="text-xs opacity-50">
									Based on{" "}
									<span class="underline">
										{impl.resource.name}
									</span>
								</p>
							</div>
						</a>
					))
				}
			</div>

			<div class="mt-6">
				<a
					href="/from_scratch"
					class="text-sm opacity-60 hover:opacity-100 transition-opacity underline"
				>
					View all implementations →
				</a>
			</div>
		</section>

		<!-- Featured Projects -->
		<section>
			<div class="mb-8">
				<h2 class="text-2xl font-serif font-bold mb-2">
					Featured Projects
				</h2>
				<p class="text-sm opacity-60">A selection of my recent work</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				{
					projects.slice(0, 2).map((project) => (
						<div class="border border-border p-6 hover:bg-muted-foreground/10 transition-colors">
							<h3 class="font-serif font-bold mb-2">
								{project.name}
							</h3>
							<p class="text-sm opacity-70 mb-4">
								{project.description}
							</p>

							<div class="flex flex-wrap gap-2 mb-4">
								{project.languages.nodes.map((language) => (
									<span class="text-xs px-2 py-1 border border-border opacity-60">
										{language.name}
									</span>
								))}
							</div>

							<a
								href={project.url}
								target="_blank"
								rel="noopener noreferrer"
								class="text-sm opacity-60 hover:opacity-100 transition-opacity underline"
							>
								View Project →
							</a>
						</div>
					))
				}
			</div>

			<div class="mt-6">
				<a
					href="/projects"
					class="text-sm opacity-60 hover:opacity-100 transition-opacity underline"
				>
					View all projects →
				</a>
			</div>
		</section>
	</div>
</Layout>
