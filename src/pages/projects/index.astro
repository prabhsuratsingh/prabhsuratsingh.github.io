---
import Layout from "../../layouts/Layout.astro"
import projects from '../../data/projects.json';

---
<Layout>
<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="mb-12">
    <h1 class="text-3xl font-serif font-bold mb-2">
      Projects
    </h1>
    <p class="text-sm opacity-60">
      Selected work and experiments
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {projects.map((project) => (
      <div
        class="border border-border p-8 hover:bg-muted-foreground/10 transition-colors group"
      >
        <h2 class="text-xl font-serif font-bold mb-3 group-hover:underline">
          {project.name}
        </h2>

        <p class="text-sm opacity-70 mb-6 leading-relaxed">
          {project.description}
        </p>

        <div class="mb-6">
          <p class="text-xs opacity-50 mb-2 uppercase tracking-wider">
            Technologies
          </p>

          <div class="flex flex-wrap gap-2">
            {project.languages.nodes.map((language) => (
              <span class="text-xs px-3 py-1 border border-border opacity-60">
                {language.name}
              </span>
            ))}
          </div>
        </div>

        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium opacity-70 hover:opacity-100 transition-opacity underline"
        >
          View Project →
        </a>
      </div>
    ))}
  </div>
  <div class="mt-12 text-center">
    <a
      href="https://github.com/prabhsuratsingh?tab=repositories"
      target="_blank"
      class="text-sm opacity-60 hover:opacity-100 transition-opacity underline"
    >
      View all projects →
    </a>
</div>
</Layout>