---
import Layout from "../../layouts/Layout.astro";
import projects from "../../data/from_scratch.json";
---

<Layout>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="mb-12">
            <h1 class="text-3xl font-serif font-bold mb-2">From Scratch</h1>

            <p class="text-sm opacity-60">
                Implementations of research papers, books, and algorithms to
                understand them from first principles.
            </p>
        </div>

        <div class="space-y-4">
            {
                projects.map((project) => (
                    <div class="flex gap-6 border border-border p-6">
                        <div class="flex-1">
                            <h2 class="text-xl font-serif font-bold mb-2">
                                {project.name}
                            </h2>

                            <p class="text-sm opacity-70 mb-4">
                                {project.description}
                            </p>

                            <div class="flex flex-wrap gap-2 mb-4">
                                {project.languages.map((lang) => (
                                    <span class="text-xs px-2 py-1 border border-border opacity-60">
                                        {lang}
                                    </span>
                                ))}
                            </div>

                            <div class="flex gap-4 text-sm">
                                <a
                                    href={project.github}
                                    target="_blank"
                                    class="underline opacity-70 hover:opacity-100"
                                >
                                    GitHub ↗
                                </a>

                                <a
                                    href={project.resource.url}
                                    target="_blank"
                                    class="underline opacity-70 hover:opacity-100"
                                >
                                    {project.resource.name} ↗
                                </a>
                            </div>
                        </div>

                        {project.image && (
                            <img
                                src={project.image}
                                alt={project.name}
                                class="hidden md:block w-48 aspect-video object-contain border border-border rounded bg-white p-2 shrink-0"
                            />
                        )}
                    </div>
                ))
            }
        </div>
    </div>
</Layout>
